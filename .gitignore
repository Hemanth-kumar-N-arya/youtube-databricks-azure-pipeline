# ============================================================
# PYTHON
# ============================================================
# Byte-compiled / optimized / DLL files — auto-generated junk
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments — never commit these
.venv/
venv/
env/
ENV/
.env

# Type checking
.mypy_cache/
.dmypy.json

# Test cache
.pytest_cache/
.coverage
htmlcov/

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# ============================================================
# AZURE FUNCTIONS
# ============================================================
# Local settings contain secrets — NEVER commit this
local.settings.json

# Azure Functions deployment packages — auto-generated
.python_packages/
.funcignore
bin/
obj/

# ============================================================
# TERRAFORM
# ============================================================
# State files contain sensitive resource info
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform plan output
*.tfplan
tfplan

# Terraform variable files with real values — use .example instead
*.tfvars

# Terraform working directory — auto-generated by terraform init
.terraform/
.terraform.lock.hcl

# ============================================================
# SECRETS & ENVIRONMENT VARIABLES
# ============================================================
# Real .env files with actual credentials
.env
.env.local
.env.production
*.env.local

# Azure credentials
azure.json
azureauth.json
credentials.json

# ============================================================
# VS CODE
# ============================================================
# Personal editor settings — each dev has their own
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# Keep these — they help the team
!.vscode/extensions.json
!.vscode/tasks.json

# ============================================================
# DATABRICKS
# ============================================================
.databricks/
*.dbc

# ============================================================
# OPERATING SYSTEM
# ============================================================
# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS (if teammates use Mac)
.DS_Store
.AppleDouble
.LSOverride

# ============================================================
# MISC
# ============================================================
# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.swp