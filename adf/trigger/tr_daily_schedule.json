{
  "name": "tr_daily_schedule",
  "type": "Microsoft.DataFactory/factories/triggers",
  "properties": {
    "description": "Runs the YouTube pipeline every day at 06:00 UTC",
    "type": "ScheduleTrigger",
    "typeProperties": {
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "startTime": "2026-01-01T06:00:00Z",
        "timeZone": "UTC"
      }
    },
    "pipelines": [
      {
        "pipelineReference": {
          "referenceName": "pl_youtube_batch_ingestion",
          "type": "PipelineReference"
        },
        "parameters": {
          "batch_date": "@formatDateTime(trigger().scheduledTime, 'yyyy-MM-dd')",
          "adls_account_name": "adlsytpipelinedev001"
        }
      }
    ]
  }
}