# Copy this file to .env for local development
# NEVER commit .env to Git
# Replace ALL values below with your real credentials in your LOCAL .env file only

AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-service-principal-client-secret-here
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_RESOURCE_GROUP=rg-ytpipeline-dev-eastus
KEY_VAULT_NAME=kv-ytpipeline-dev-001
YOUTUBE_API_KEY=your-youtube-api-key-here
DATABRICKS_HOST=https://adb-XXXXXXXXXXXXXXXX.X.azuredatabricks.net
DATABRICKS_TOKEN=your-databricks-pat-token-here
